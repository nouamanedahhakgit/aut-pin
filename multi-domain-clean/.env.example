# Multi-Domain System Configuration
# Copy this file to .env and configure your values

# ============================================
# SYSTEM CONFIGURATION (REQUIRED)
# ============================================

# Database backend: mysql | supabase
DB_BACKEND=mysql

# MySQL (when DB_BACKEND=mysql)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=pinterest

# Supabase / PostgreSQL (when DB_BACKEND=supabase)
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Security (change this to a random string)
SECRET_KEY=your-secret-key-change-this-to-random-string

# ============================================
# MICROSERVICES – API base URLs
# ============================================
# multi-domain-clean calls these services over HTTP. Set to your deployment URLs.
# Defaults assume each service runs on localhost with the port below.
GENERATE_ARTICLE_API_URL=http://localhost:5002   # articles-website-generator (uvicorn, port 5002)
WEBSITE_PARTS_API_URL=http://localhost:5003     # website-parts-generator (uvicorn, port 5003)
PIN_API_URL=http://localhost:5000                # pin_generator (python generator.py --serve, port 5000)
PIN_EDITOR_URL=http://localhost:5004             # optional: pin editor (serve.py, port 5004)

# When R2 is not configured in Profile, images are stored under data/hosted_images/ and served at /api/hosted-images/...
# Set this to your public site URL (no trailing slash) so bulk jobs / Pinterest get absolute image links.
# PUBLIC_BASE_URL=https://your-domain.com
# HOSTED_IMAGES_DIR=  # optional override; default: multi-domain-clean/data/hosted_images
