      "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Pin</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&display=swap');\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        body { display: flex; justify-content: center; align-items: center; min-height: 100vh; background: #f0f0f0; font-family: 'Montserrat', sans-serif; }\n        .pin-container { width: 736px; height: 1472px; background: linear-gradient(135deg, #F5A623 0%, #F7B731 100%); position: relative; overflow: hidden; box-shadow: 0 10px 40px rgba(0,0,0,0.1); }\n        .header-text { text-align: center; padding-top: 60px; color: white; }\n        .small-title { font-size: 42px; font-weight: 600; letter-spacing: 4px; text-transform: uppercase; margin-bottom: 10px; }\n        .main-title { font-size: 130px; font-weight: 900; line-height: 0.9; text-transform: uppercase; letter-spacing: -2px; margin: 0 20px; text-shadow: 0 4px 8px rgba(0,0,0,0.1); }\n        .badge { display: inline-block; background: #000; color: white; padding: 18px 40px; border-radius: 50px; font-size: 38px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin-top: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }\n        .image-section { position: relative; margin-top: 40px; padding: 0 40px; }\n        .main-image { width: 656px; height: 875px; background: url('{{main_image}}') center/cover; border-radius: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); position: relative; overflow: hidden; }\n        .curly-arrow { position: absolute; left: -20px; top: 200px; width: 120px; height: 200px; z-index: 10; }\n        .curly-arrow svg { width: 100%; height: 100%; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2)); }\n        .footer { position: absolute; bottom: 0; left: 0; right: 0; background: #8B5A2B; padding: 35px; text-align: center; }\n        .url-text { color: white; font-size: 32px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; }\n    </style>\n</head>\n<body>\n    <div class=\"pin-container\">\n        <div class=\"header-text\">\n            <div class=\"small-title\">{{small_title}}</div>\n            <div class=\"main-title\">{{title}}</div>\n            <div class=\"badge\">{{badge}}</div>\n        </div>\n        <div class=\"image-section\">\n            <div class=\"curly-arrow\">\n                <svg viewBox=\"0 0 100 150\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M80 20C60 20 40 40 40 60C40 80 60 90 70 100C80 110 90 120 80 130\" stroke=\"white\" stroke-width=\"6\" stroke-linecap=\"round\" fill=\"none\"/><path d=\"M70 115L80 130L90 120\" stroke=\"white\" stroke-width=\"6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"/></svg>\n            </div>\n            <div class=\"main-image\"></div>\n        </div>\n        <div class=\"footer\">\n            <div class=\"url-text\">www.{{domain}}</div>\n        </div>\n    </div>\n</body>\n</html>"
