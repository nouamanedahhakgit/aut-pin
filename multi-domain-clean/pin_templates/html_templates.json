      "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Pin</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Inter:wght@400;600;800&display=swap');\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        body { min-height: 100vh; display: flex; justify-content: center; align-items: center; background: #f5f5f5; padding: 20px; }\n        .pin-container { width: 736px; height: 1472px; background: white; border-radius: 24px; overflow: hidden; box-shadow: 0 25px 80px rgba(0,0,0,0.12); position: relative; }\n        .quad-grid { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; height: 100%; gap: 0; }\n        .quad-item { position: relative; overflow: hidden; }\n        .quad-item img { width: 100%; height: 100%; object-fit: cover; }\n        .center-content { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 85%; text-align: center; z-index: 10; background: rgba(255,255,255,0.98); padding: 40px 30px; border-radius: 8px; box-shadow: 0 20px 60px rgba(0,0,0,0.2); }\n        .number { font-family: Inter, sans-serif; font-size: 52px; font-weight: 800; color: #4a7c59; line-height: 1; margin-bottom: 5px; }\n        .subtitle { font-family: Inter, sans-serif; font-size: 14px; font-weight: 600; color: #4a7c59; text-transform: uppercase; letter-spacing: 3px; margin-bottom: 15px; }\n        .main-title { font-family: 'Playfair Display', serif; font-size: 56px; font-weight: 900; color: #1a1a1a; line-height: 0.95; margin-bottom: 10px; text-transform: uppercase; }\n        .secondary-title { font-family: Inter, sans-serif; font-size: 18px; font-weight: 400; color: #333; text-transform: uppercase; letter-spacing: 4px; margin-bottom: 25px; }\n        .site-url { font-family: Inter, sans-serif; font-size: 13px; font-weight: 600; color: #666; letter-spacing: 3px; text-transform: uppercase; }\n    </style>\n</head>\n<body>\n    <div class=\"pin-container\">\n        <div class=\"quad-grid\">\n            <div class=\"quad-item\"><img src=\"{{main_image}}\" alt=\"\" style=\"object-position: top left;\"></div>\n            <div class=\"quad-item\"><img src=\"{{main_image}}\" alt=\"\" style=\"object-position: top right;\"></div>\n            <div class=\"quad-item\"><img src=\"{{main_image}}\" alt=\"\" style=\"object-position: bottom left;\"></div>\n            <div class=\"quad-item\"><img src=\"{{main_image}}\" alt=\"\" style=\"object-position: bottom right;\"></div>\n            <div class=\"center-content\">\n                <span class=\"number\">{{number}}</span>\n                <div class=\"subtitle\">{{subtitle}}</div>\n                <h1 class=\"main-title\">{{main_title}}</h1>\n                <div class=\"secondary-title\">{{secondary_title}}</div>\n                <div class=\"site-url\">{{domain}}</div>\n            </div>\n        </div>\n    </div>\n</body>\n</html>"
    }
