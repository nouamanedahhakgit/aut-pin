      },
      "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Pin</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Pacifico&family=Roboto+Condensed:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        body { min-height: 100vh; display: flex; justify-content: center; align-items: center; background: #e8e6e1; padding: 20px; }\n        .pin-container { width: 736px; height: 1472px; background: white; border-radius: 30px; overflow: hidden; box-shadow: 0 30px 80px rgba(0,0,0,0.18); position: relative; }\n        .image-wrapper { position: relative; height: 100%; background: #f0ebe3; overflow: hidden; }\n        .chowder-image { width: 100%; height: 100%; object-fit: cover; }\n        .content-band { position: absolute; top: 50%; left: 0; transform: translateY(-50%); width: 100%; background: #5a7247; padding: 60px 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.3); z-index: 10; }\n        .ribbon { position: absolute; top: -30px; left: 50%; transform: translateX(-50%); width: 80%; height: 80px; background: #c9a66b; z-index: 15; display: flex; align-items: center; justify-content: center; box-shadow: 0 5px 20px rgba(0,0,0,0.2); }\n        .ribbon-text { font-family: 'Playfair Display', serif; font-size: 42px; color: white; font-style: italic; text-shadow: 2px 2px 4px rgba(0,0,0,0.3); }\n        .main-content { text-align: center; position: relative; z-index: 10; }\n        .the-text { font-family: Pacifico, cursive; font-size: 48px; color: #c9a66b; text-shadow: 2px 2px 4px rgba(0,0,0,0.3); margin-bottom: -10px; }\n        .best-text { font-family: 'Playfair Display', serif; font-size: 64px; font-weight: 700; color: white; text-shadow: 3px 3px 6px rgba(0,0,0,0.4); line-height: 1; margin: 10px 0; }\n        .recipe-title { font-family: 'Roboto Condensed', sans-serif; font-size: 52px; font-weight: 700; color: #f4d03f; text-transform: capitalize; line-height: 1.1; text-shadow: 2px 2px 4px rgba(0,0,0,0.4); margin-top: 20px; }\n    </style>\n</head>\n<body>\n    <div class=\"pin-container\">\n        <div class=\"image-wrapper\">\n            <img src=\"{{main_image}}\" alt=\"\" class=\"chowder-image\">\n            <div class=\"content-band\">\n                <div class=\"ribbon\"><span class=\"ribbon-text\">{{ribbon_text}}</span></div>\n                <div class=\"main-content\">\n                    <div class=\"the-text\">{{ribbon_text}}</div>\n                    <div class=\"best-text\">{{best_text}}</div>\n                    <h1 class=\"recipe-title\">{{recipe_title}}</h1>\n                </div>\n            </div>\n        </div>\n    </div>\n</body>\n</html>"
    }
  }
]
