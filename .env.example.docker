# Docker Compose – environment template
# Copy relevant vars to multi-domain-clean/.env (and other service .env) before running.

# ============================================
# DATABASE (multi-domain-clean)
# ============================================
# DB_BACKEND=mysql
# MYSQL_HOST=host.docker.internal
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=pinterest

# Or use Supabase (external):
# DB_BACKEND=supabase
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ============================================
# SECRET
# ============================================
# SECRET_KEY=your-secret-key-change-this

# ============================================
# AI (OpenAI / OpenRouter)
# ============================================
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# ============================================
# DOCKER HUB (for docker-compose.hub.yml)
# ============================================
# DOCKERHUB_USERNAME=your_dockerhub_username
